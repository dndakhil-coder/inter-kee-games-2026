# ============================================
# VERCEL POSTGRES SETUP (FREE)
# ============================================

# Get this from Vercel Postgres storage
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.vercel-postgres.com/verceldb

# Change this to a secure random string
JWT_SECRET=your-super-secret-key-change-this-in-production-12345

# Your frontend URL (set after frontend deploys)
FRONTEND_URL=https://your-frontend-url.vercel.app

# Server port (Vercel sets this automatically)
PORT=3001

# Node environment
NODE_ENV=production

# ============================================
# HOW TO GET DATABASE_URL:
# 1. Go to vercel.com
# 2. Dashboard → Storage → Create Postgres
# 3. Copy .env.local content
# 4. Paste DATABASE_URL above
# ============================================
